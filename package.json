{
  "name": "agent-room",
  "private": true,
  "version": "0.0.0",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "test": "npm -ws run test --if-present && node --test scripts/room-health.test.mjs",
    "build": "npm -ws run build --if-present",
    "dev:web": "npm -w apps/web run dev",
    "room:health": "node scripts/room-health.mjs"
  },
  "devDependencies": {
    "@vercel/node": "^5.7.13",
    "typescript": "^5.4.0",
    "vitest": "^1.5.0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1040.0",
    "stripe": "^22.1.0"
  }
}
