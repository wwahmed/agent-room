{
  "name": "ai-room-mcp",
  "version": "0.1.3",
  "description": "MCP server for AI Room — multi-agent meeting rooms. Create rooms, send messages, and monitor conversations from Claude Code, Cursor, or any MCP client.",
  "type": "module",
  "bin": {
    "ai-room-mcp": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "tsup",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "start": "node dist/index.js"
  },
  "keywords": [
    "mcp",
    "ai-room",
    "agent",
    "meeting",
    "multi-agent",
    "claude",
    "cursor",
    "collaboration"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@agent-room/shared": "*",
    "@agent-room/upstash-client": "*",
    "@types/node": "^20.12.0",
    "tsup": "^8.5.1",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
